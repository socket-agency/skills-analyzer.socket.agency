# Skill Analyzer — deployment environment.
# Copy to `.env` and fill in. NEVER commit real keys. All keys are SERVER-SIDE ONLY —
# they are never sent to the browser.

# ── LLM judge panel ─────────────────────────────────────────────────────────
# The judge panel is OFF unless JUDGE_LIVE=1. When off (=0 or unset), the analyzer
# is purely static/deterministic — no outbound LLM calls, no provider key needed.
#
# ⚠ Setting JUDGE_LIVE=1 OPTS IN to live dispatch: every scan calls out to the LLM
#   gateway (LiteLLM → OpenRouter), which costs money and adds latency. It REQUIRES a
#   provider key below. The engine degrades safely (judges abstain) on any error.
#   This deployment intends live judges; set =0 to fall back to static-only.
JUDGE_LIVE=1

# Provider keys consumed by LiteLLM. Supply the gateway key you actually use.
# (OpenRouter is the default gateway; a single key covers the stratified registry.)
OPENROUTER_API_KEY=
# Optional direct-provider keys if you reconfigure the registry in analyzer/config.py:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Optional LiteLLM overrides.
# LITELLM_LOG=ERROR

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8000

# ── Egress allowlist (enforce at the platform/firewall layer, see README) ────
# The app should only be permitted to reach:
#   - the LLM gateway:  openrouter.ai  (or your configured LiteLLM endpoint)
#   - the OSV database:  api.osv.dev
# Everything else (including arbitrary hosts from a scanned git URL's content)
# must be blocked. The git CLONE itself reaches the submitted host — run it behind
# the same controls you apply to any user-supplied URL fetch.
